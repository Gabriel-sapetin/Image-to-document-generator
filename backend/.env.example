# Application Settings
APP_NAME="Image-to-Document API"
DEBUG=False
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Files
MAX_FILE_SIZE=52428800
UPLOAD_DIR=uploads/temp
OUTPUT_DIR=uploads/output
SESSION_DIR=uploads/sessions

# Sessions
SESSION_TTL=3600
CLEANUP_INTERVAL=300

# CORS
CORS_ORIGINS=["*"]

# Database (optional)
DATABASE_URL=sqlite:///./app.db